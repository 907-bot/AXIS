# AXIS Environment Configuration

# Application
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/axis
QDRANT_HOST=localhost
QDRANT_PORT=6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LLM
OPENAI_API_KEY=your-api-key-here
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7

# Camera
CAMERA_FPS=30
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# GPU
CUDA_ENABLED=true
GPU_DEVICE=0

# Models (paths to downloaded checkpoints)
SAM_MODEL_PATH=models/sam2.1_hiera_large.pt
DINO_MODEL_PATH=models/dinov2_vitl14